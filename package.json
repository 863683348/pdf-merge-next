{
  "name": "pdf-merge-next",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "纯浏览器端、零上传、零注册的 PDF 合并工具（MergeLocal）· Next.js + Vercel 出海版",
  "scripts": {
    "copy:pdfjs": "node scripts/copy-pdfjs-assets.mjs",
