    "@fontsource/noto-sans-sc": "^5.0.13",
    "file-saver": "^2.0.5",
    "lucide-react": "^0.439.0",
    "next": "^15.5.20",
    "pdf-lib": "1.17.1",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/file-saver": "^2.0.7",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.20",
